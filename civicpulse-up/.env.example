# CivicPulse UP — Environment Variables
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit your actual .env file to GitHub

# Backend Server
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/civicpulse

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Google Gemini AI
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY

# WhatsApp Business API (Meta for Developers)
WA_ACCESS_TOKEN=your-whatsapp-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_VERIFY_TOKEN=civicpulse-verify-2024
WHATSAPP_PHC_NUMBER=91XXXXXXXXXX
WHATSAPP_CMO_NUMBER=91XXXXXXXXXX

# Bhashini / AI4Bharat NLP
BHASHINI_API_KEY=your-bhashini-key

# Internal API Key (for ML engine → backend calls)
INTERNAL_API_KEY=civicpulse-internal-secret

# SLA Configuration
SLA_HOURS=4
